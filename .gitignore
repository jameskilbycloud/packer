# Cache objects
packer_cache/

# Crash log
crash.log

# https://www.packer.io/guides/hcl/variables
# Exclude all .pkrvars.hcl files, which are likely to contain sensitive data,
# such as password, private keys, and other secrets. These should not be part of
# version control as they are data points which are potentially sensitive and
# subject to change depending on the environment.
#
*.pkrvars.hcl

# For built boxes
*.box

# Packer build manifests (generated on each run — ignore the JSON outputs but
# keep the directory itself so the post-processor can write into it)
manifests/*.json

# Temporary runner vars file written by CI
runner.pkrvars.hcl

# OS metadata files — written by Finder / Explorer, never useful in the repo
.DS_Store
Thumbs.db
desktop.ini

# Claude Code transient artifacts
.claude/

# CI-runtime artefacts the workflows write into the runner's checkout.
# In normal operation these are uploaded as workflow artifacts and never
# land in the repo, but a tracking hiccup (or a local `packer build`) can
# spill them onto disk where they'd otherwise be staged on the next add.
packer-*.log
build-metrics-*.json
screenshots-*/
smoke-screenshots-*/
