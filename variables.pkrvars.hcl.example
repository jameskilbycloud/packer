# =============================================================================
# variables.pkrvars.hcl.example
# =============================================================================
# Copy this file to variables.pkrvars.hcl and fill in your values.
# NEVER commit variables.pkrvars.hcl to version control — it contains secrets.
# The .gitignore already covers *.pkrvars.hcl so the copy is ignored automatically.
# =============================================================================

# ── vSphere Connection ────────────────────────────────────────────────────────
vsphere_server              = "vcenter.example.com"
vsphere_user                = "administrator@vsphere.local"
vsphere_password            = "REPLACE_ME"
vsphere_insecure_connection = false   # Set true only if using a self-signed cert

# ── vSphere Infrastructure ────────────────────────────────────────────────────
vsphere_datacenter    = "Datacenter"
vsphere_cluster       = "Cluster01"   # Leave as "" to target a specific host instead
vsphere_host          = ""            # e.g. "esxi01.example.com" (only if cluster is "")
vsphere_datastore     = "datastore1"
vsphere_network       = "VM Network"
vsphere_folder        = "Templates/Ubuntu"

# ── Build Credentials ─────────────────────────────────────────────────────────
build_username = "ubuntu"
build_password = "Packer#Build2024!"   # Must match the hash below

# Generate the encrypted hash with:
#   openssl passwd -6 'Packer#Build2024!'
build_password_encrypted = "$6$rounds=4096$REPLACE_WITH_REAL_SALT$REPLACE_WITH_REAL_HASH"

# ── VM Hardware — Server ──────────────────────────────────────────────────────
server_cpu_count = 2
server_ram_mb    = 2048
server_disk_gb   = 40

# ── VM Hardware — Desktop ─────────────────────────────────────────────────────
desktop_cpu_count = 4
desktop_ram_mb    = 4096
desktop_disk_gb   = 60

# ── VM Hardware — General ─────────────────────────────────────────────────────
# 19 = vSphere 7.0 U2+  |  20 = vSphere 8.0  |  21 = vSphere 8.0 U2+
vm_hardware_version = 19

# ── ISO Source ────────────────────────────────────────────────────────────────
# ISOs can come from a regular datastore folder OR a vSphere Content Library.
# The builder uses vSphere's [name] path notation for both — just set
# vsphere_iso_datastore to the datastore or content library name.
#
# Option A — Datastore (include the subfolder in the ISO path):
#   vsphere_iso_datastore = "datastore1"
#   ubuntu_2404_iso_path  = "ISOs/ubuntu-24.04.4-live-server-amd64.iso"
#
# Option B — Content Library (filename only, no subfolder):
#   vsphere_iso_datastore = "MyContentLibrary"
#   ubuntu_2404_iso_path  = "ubuntu-24.04.4-live-server-amd64.iso"
#
# Download ISOs from: https://releases.ubuntu.com

vsphere_iso_datastore = "datastore1"

# Datastore that physically backs the Content Library (used by the ISO upload
# workflow). Usually the same as vsphere_datastore. Only set this if the library
# is backed by a different datastore.
# vsphere_iso_library_datastore = "datastore1"

ubuntu_2204_iso_path = "ISOs/ubuntu-22.04.5-live-server-amd64.iso"
ubuntu_2404_iso_path = "ISOs/ubuntu-24.04.4-live-server-amd64.iso"
ubuntu_2604_iso_path = "ISOs/ubuntu-26.04-live-server-amd64.iso"

# ── Windows ───────────────────────────────────────────────────────────────────
# Windows ISOs are NOT auto-downloaded — Microsoft requires accepting a EULA
# and the URLs are session-bound. Download manually from the Microsoft Eval
# Center (or use your own licensed media) and upload to the Content Library:
#
#   - Server 2022:  https://www.microsoft.com/evalcenter/evaluate-windows-server-2022
#   - Server 2025:  https://www.microsoft.com/evalcenter/evaluate-windows-server-2025
#   - Windows 10:   https://www.microsoft.com/evalcenter/evaluate-windows-10-enterprise
#
# Then set the path here (filename only for a Content Library, folder/file
# for a regular datastore).

windows_server_2022_iso_path = "ISOs/SERVER_EVAL_x64FRE_en-us.iso"
windows_server_2025_iso_path = "ISOs/SERVER_2025_EVAL_x64FRE_en-us.iso"
windows_10_iso_path          = "ISOs/Win10_22H2_EnglishInternational_x64.iso"

# Image name selects the edition installed from the ISO. Defaults match the
# Eval Center media. Use `Get-WindowsImage -ImagePath D:\sources\install.wim`
# (or `.esd`) on a Windows host to list available image names.
windows_server_2022_image_name = "Windows Server 2022 SERVERSTANDARD"
windows_server_2025_image_name = "Windows Server 2025 SERVERSTANDARD"
windows_10_image_name          = "Windows 10 Enterprise Evaluation"

# Windows admin password — used by autounattend to set the built-in
# Administrator and by Packer's WinRM connection. Must satisfy Windows
# complexity (≥ 8 chars, 3 of 4 character classes).
windows_admin_password = "Packer#Build2024!"

# Windows timezone (different ID system to IANA).
# Run `tzutil /l` on a Windows host for the full list.
windows_timezone = "GMT Standard Time"

# ── VM Hardware — Windows ─────────────────────────────────────────────────────
windows_server_cpu_count  = 2
windows_server_ram_mb     = 4096
windows_server_disk_gb    = 60

windows_desktop_cpu_count = 2
windows_desktop_ram_mb    = 4096
windows_desktop_disk_gb   = 60
